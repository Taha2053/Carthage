# ============================================================
# UCAR Intelligence Hub — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Supabase PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Redis Cloud
REDIS_URL=redis://default:password@redis-xxxxx.c1.eu-central-1-1.ec2.redns.redis-cloud.com:6379

# JWT Auth
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# OpenAI (teammate's agents)
OPENAI_API_KEY=sk-xxxxx

# App
APP_NAME=UCAR Intelligence Hub
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=["http://localhost:4200","http://localhost:3000","http://localhost:5173"]
